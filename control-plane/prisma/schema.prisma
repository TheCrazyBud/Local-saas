generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Deployment {
  id        String   @id @default(uuid())
  name      String
  region    String
  status    String   @default("Operational")
  vpcId     String
  createdAt DateTime @default(now())
}

model Agent {
  id          String   @id @default(uuid())
  name        String
  description String
  status      String   @default("Operational")
  createdAt   DateTime @default(now())
}

model ActionApproval {
  id          String   @id @default(uuid())
  agentName   String
  actionType  String
  payload     String   
  status      String   @default("PENDING") 
  createdAt   DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(uuid())
  event     String
  location  String
  status    String   
  createdAt DateTime @default(now())
}
